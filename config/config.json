{
  "pxy_backend_file": "config/backend.json",
  "pxy_frontend_file": "config/frontend.json",
  "domain_map": "config/domains.json",
  "plugin": {
    "enabled": true,
    "root": "plugins",
    "plugins": []
  },
  "proxy": {
    "flush_interval": 0,
    "buf_size": 65536,
    "transport": "fasthttp",
    "proxy_mode": "fasthttp",
    "net_io": "nbio",
    "max_conns_per_host": 100,
    "idle_conn_timeout": 60
  },
  "error_config": {
    "error_mode": "html",
    "enable_page_cache": true,
    "error_page": {
      "403": "static/403.html",
      "404": "static/404.html",
      "429": "static/429.html",
      "500": "static/500.html",
      "502": "static/502.html"
    }
  },
  "servers": [
    {
      "name": "http-server",
      "host": "0.0.0.0",
      "port": 80,
      "use_http2": true,
      "protocol": "http",
      "enabled": true,
      "max_request_body": 52428800,
      "domains": [
        {
          "domains": ["renj.io", "service.renj.io", "dev.renj.io", "blog.renj.io",
            "me.renj.io", "gallery.renj.io", "jjapp.renj.io", "pkg.renj.io"],
          "auto_redirect": true
        }
      ]
    },
    {
      "name": "https-server",
      "host": "0.0.0.0",
      "port": 443,
      "use_http2": true,
      "protocol": "https",
      "http2": {
        "max_concurrent_streams": 128,
        "max_handlers": 100,
        "idle_timeout": 60,
        "read_idle_timeout": 60
      },
      "enabled": true,
      "max_request_body": 52428800,
      "tls": {
        "min_version": "TLS13",
        "cert_map": {
          "renj.io": {
            "domains": ["renj.io", "service.renj.io", "pkg.renj.io", "dev.renj.io", "blog.renj.io", "me.renj.io", "gallery.renj.io"],
            "cert_file": "config/ssl/fullchain.cer",
            "key_file": "config/ssl/ssl.key"
          }
        },
        "auto_tls": false
      },
      "domains": [
        {
          "domains": ["renj.io", "service.renj.io"]
        }
      ]
    }
  ],
  "middleware": {
    "cors": {
      "enabled": true,
      "header": ["Content-Type", "Origin", "Authorization", "access-token", "Token"]
    },
    "trace": {
      "enabled": true,
      "trace_id": "X-Gateway-Trace-Id"
    },
    "secure_header": true,
    "gzip": {
      "enabled": true,
      "level": 6,
      "types": [
        "text/html",
        "text/css",
        "text/javascript",
        "text/plain",
        "text/xml",
        "application/javascript",
        "application/xml",
        "application/json",
        "font/ttf",
        "font/woff",
        "font/woff2",
        "font/otf"
      ],
      "threshold": 2048
    }
  },
  "features": {
    "flow_control": {
      "enabled": true,
      "global_limit": {
        "requests": 10000,
        "window": "60s",
        "unit": "s"
      },
      "rules": [
        {
          "name": "api-limit",
          "enabled": true,
          "priority": 1,
          "match_type": "host",
          "match_value": "renj.io",
          "header_key": "",
          "limits": [
            {
              "requests": 1000,
              "window": "10s",
              "unit": "s"
            },
            {
              "requests": 5000,
              "window": "10min",
              "unit": "min"
            }
          ],
          "action": "block",
          "description": "API服务限流"
        }
      ],
      "recording": {
        "enabled": false,
        "record_blocked": true,
        "record_allowed": false,
        "storage_type": "file",
        "retention_period": "30d"
      }
    },
    "websocket": {
      "enabled": true
    },
    "proxy_cache": {
      "enabled": true,
      "cache_size": 2048,
      "cache_ttl": 3600
    }
  },
  "database": {
    "mongo": {
      "url": "mongodb://localhost:27017",
      "database": "ApolloMongo",
      "timeout": 10
    },
    "influx": {
      "enabled": false,
      "url": "http://localhost:8086",
      "token": "",
      "org": "sandwich",
      "bucket": "sandwich",
      "password": ""
    }
  },
  "security": {
    "strict_mode": true,
    "allow_ips": [],
    "deny_ips": [],
    "rate_limit": 1000
  },
  "proxy_header": {
    "trace_id": "X-Gateway-Trace-Id",
    "frontend_host_header": "X-Proxy-Internal-Host",
    "backend_header": "X-Proxy-Internal-Local",
    "proxy_app": "X-Proxy-Backend",
    "forward_host_header": "X-Forward-Host"
  },
  "log": {
    "log_level": "debug",
    "log_file": "",
    "color": true
  },
  "module": null,
  "api_server_config": {
    "enabled": true,
    "host": "127.0.0.1",
    "port": 8888,
    "http2": {
      "enabled": true,
      "insecure": true
    },
    "bblot": {
      "enabled": true,
      "file": "data/hamburger-api.db"
    }
  },
  "stat": {
    "db_file": "data/stat.db",
    "use_db": true,
    "compatible": true,
    "enabled": true,
    "enable_stat": true,
    "sync_duration": 720,
    "save_duration": 3600,
    "save_file": "data/stat.json",
    "geo_file": "data/geo.json",
    "domain_file": "data/domain.json",
    "geo_db": "",
    "sequence": {
      "enabled": false,
      "interval": 3600
    }
  },
  "custom_header": {
    "Proxy-Copyright": "renj.io",
    "Proxy-Server": "Hamburger"
  },
  "syncer": {
    "job_sync_domains": 60,
    "job_sync_domain_ports": 60
  },
  "debug": true,
  "pprof": {
    "enable": false,
    "port": 8889
  },
  "max_cores": 4,
  "pxy_backend": {},
  "pxy_frontend": {},
  "exp_config": {
    "trojan_server": "config/trojan.json"
  }
}
