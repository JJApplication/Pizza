    "enabled": true,
    "http2": {
      "read_timeout": 30,
      "write_timeout": 30,
      "idle_timeout": 60,
      "read_header_timeout": 10,
      "max_header_bytes": 5242880,
      "keep_alive": 30,
      "max_handlers": 256,
      "max_concurrent_streams": 512,
      "max_upload_buffer_per_connection": 16777216,
      "max_upload_buffer_per_stream": 16777216
    },
    "http3": {
      "enabled": false,
      "host": "",
      "port": 0,
      "cert_file": "",
      "key_file": "",
      "max_connections": 100,
      "idle_timeout": 60,
      "keep_alive": 30,
      "insecure_skip_verify": true
    }
  },
  "cache": {
    "enable": true,
    "dir": "/renj.io/cache",
    "expire": 0,
    "matcher": [
      "*.html",
      "*.css",
      "*.js",
      "*.svg",
      "*.ico",
      "*.woff",
      "*.woff2",
      "*.ttf",
      "*.otf",
      "*.eot",
      "*.map"
    ]
  },
  "internal_flag": "X-Proxy-Internal-Front",
  "internal_local_flag": "X-Proxy-Internal-Local",
  "internal_backend_flag": "X-Proxy-Backend",
  "cache_header": "X-Helios-Cache",
